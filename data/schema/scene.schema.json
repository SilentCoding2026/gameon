{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://offline-animation-engine.local/schema/scene.schema.json",
  "title": "Scene",
  "description": "A composition of scene nodes referencing assets.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique scene identifier."
    },
    "name": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SceneNode"
      }
    }
  },
  "required": ["schema_version", "id", "name", "nodes"],
  "additionalProperties": false,
  "$defs": {
    "SceneNode": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "parent": {
          "type": ["string", "null"],
          "description": "Parent node id, or null for root nodes."
        },
        "transform": {
          "$ref": "#/$defs/Transform"
        }
      },
      "required": ["id", "parent", "transform"],
      "additionalProperties": false
    },
    "Transform": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "rotation": { "type": "number" },
        "scaleX": { "type": "number" },
        "scaleY": { "type": "number" }
      },
      "required": ["x", "y", "rotation", "scaleX", "scaleY"],
      "additionalProperties": false
    }
  }
}
