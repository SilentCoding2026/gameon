{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://offline-animation-engine.local/schema/approval.schema.json",
  "title": "Approval",
  "description": "Human approval record. Export is BLOCKED unless approved is true.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "approved": {
      "type": "boolean",
      "default": false,
      "description": "Must be true for any export operation."
    },
    "approved_by": {
      "type": "string",
      "description": "Name or identifier of the human who approved."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of approval."
    }
  },
  "required": ["schema_version", "approved", "approved_by", "timestamp"],
  "additionalProperties": false
}
